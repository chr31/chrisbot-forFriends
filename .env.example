# ============================================================================
# Required for a basic local backend startup
# ============================================================================

# Core application
PORT=3000
TZ=Europe/Rome
ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret

# Frontend runtime
# In Docker Compose il proxy API del frontend usa BACKEND_URL=http://chrisbot:3000
# via compose environment, quindi di solito non serve impostarlo qui.
NEXT_PUBLIC_API_URL=
BACKEND_URL=
BACKEND_INSECURE_SKIP_TLS_VERIFY=false
BACKEND_CA_CERT=

# MySQL connection
# Lascia MYSQL_HOST=mysql e COMPOSE_PROFILES=local-mysql per usare il container
# MySQL incluso in Docker Compose.
# Imposta MYSQL_HOST a un host esterno e COMPOSE_PROFILES vuoto per usare un
# database MySQL gia' esistente senza creare il container MySQL.
#
# Per avviare anche il container Neo4j locale del Memory Engine, aggiungi
# local-neo4j a COMPOSE_PROFILES:
# COMPOSE_PROFILES=local-mysql,local-neo4j
COMPOSE_PROFILES=local-mysql
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_HOST_PORT=3307
MYSQL_USER=chrisbot
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=chrisbot
MYSQL_ROOT_PASSWORD=change-root-password
MYSQL_CONNECTION_LIMIT=10
MYSQL_TZ=Z

# Neo4j local container for Memory Engine.
# ON: aggiungi local-neo4j a COMPOSE_PROFILES.
# OFF: ometti local-neo4j da COMPOSE_PROFILES.
# Il backend usera' queste credenziali solo dopo la configurazione UI dello step 3.
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j
NEO4J_HTTP_HOST_PORT=7474
NEO4J_BOLT_HOST_PORT=7687

# Optional container DNS override.
# If omitted, Docker Compose falls back to 8.8.8.8 and 8.8.4.4.
CHRISBOT_DNS_1=
CHRISBOT_DNS_2=

# ============================================================================
# Optional integrations and feature-specific settings
# ============================================================================

# Scheduler / diagnostics
TASK_SCHEDULER_RECONCILE_MS=15000
LOG_NOTIF_DELETE=0
